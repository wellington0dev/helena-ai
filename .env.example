# ==== Helena — configuração do servidor ====
# Copie para .env (o instalador faz isso) e rode `./helena setup`.

# Cérebro da Helena: 'gemini' (nuvem) ou 'ollama' (modelo local). Escolhido
# no `helena setup` — mude depois com `helena provider gemini|ollama`.
LLM_PROVIDER=gemini

# Chave da API do Google Gemini (obrigatória se LLM_PROVIDER=gemini) —
# https://ai.google.dev/. Sempre necessária pra geração de imagem/TTS e
# descrição de mídia enviada, mesmo em modo local (o Ollama não faz isso).
GEMINI_API_KEY=

# Segredo para assinar tokens JWT. Gerado automaticamente pelo `helena setup`.
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Rede
HELENA_PORT=5000
HELENA_HOST=0.0.0.0

# ---- Opcionais (têm default sensato) ----
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE=Kore
# DATABASE_URL=sqlite:///./data/helena.db
# HELENA_DATA_DIR=./data
# HELENA_MEDIA_DIR=./data/media

# ---- Modelo local (Ollama) — só relevante com LLM_PROVIDER=ollama ----
# Configurado por `helena setup` (modo local) ou `helena models`/`provider`.
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_MANAGED=1
# OLLAMA_REQUEST_TIMEOUT_SECONDS=300

# Notificação nativa do desktop onde o servidor roda (toast do SO), além da
# fila que o app mobile puxa. '0' desliga (útil em VPS/servidor headless).
# HELENA_DESKTOP_NOTIFICATIONS=1

# ---- Telegram (opcional): a Helena como bot completo no Telegram ----
# Token do bot criado no @BotFather. Vazio = bot desligado. Com o token,
# fale com o bot e envie /login pra entrar com email+senha (como no helena chat).
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_POLL_TIMEOUT=50
