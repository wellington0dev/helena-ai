# ==== Helena — configuração do servidor ====
# Copie para .env (o instalador faz isso) e rode `./helena setup`.

# Chave da API do Google Gemini (obrigatória) — https://ai.google.dev/
GEMINI_API_KEY=

# Segredo para assinar tokens JWT. Gerado automaticamente pelo `helena setup`.
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Rede
HELENA_PORT=5000
HELENA_HOST=0.0.0.0

# ---- Opcionais (têm default sensato) ----
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE=Kore
# DATABASE_URL=sqlite:///./data/helena.db
# HELENA_DATA_DIR=./data
# HELENA_MEDIA_DIR=./data/media

# Notificação nativa do desktop onde o servidor roda (toast do SO), além da
# fila que o app mobile puxa. '0' desliga (útil em VPS/servidor headless).
# HELENA_DESKTOP_NOTIFICATIONS=1

# ---- Federação (comunicação com outras instâncias da Helena) ----
# URL pública desta instância (Tailscale Funnel/port-forward + https://) —
# sem isso, dá pra RECEBER pareamento/mensagens mas não INICIAR pareamento.
# FEDERATION_PUBLIC_URL=https://sua-instancia.exemplo.ts.net
# FEDERATION_REPLAY_WINDOW_SECONDS=300
# FEDERATION_PAIRING_TTL_SECONDS=600
# FEDERATION_HTTP_TIMEOUT_SECONDS=10
